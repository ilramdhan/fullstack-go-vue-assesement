# HTTP
HTTP_ADDR=:8080

# Database (sqlite)
DATABASE_PATH=data/dashboard.db

# JWT
JWT_SECRET=replace-me-with-output-of-make-gen-secret
JWT_EXPIRED=24h

# OpenAPI spec location (used by validator middleware)
OPENAPIYAML_LOCATION=../openapi.yaml

# CORS — comma-separated allowed origins for the dashboard frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000
